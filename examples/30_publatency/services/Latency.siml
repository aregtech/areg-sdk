        <DataType ID="416" Name="LantencySetup" Type="Structure">
            <Description>Latency test setup structure.</Description>
            <FieldList>
                <Field ID="417" Name="mode" DataType="LatencyMode">
                    <Value IsDefault="true">Latency::LatencyMode::Stop</Value>
                    <Description>The latency benchmark mode.</Description>
                </Field>
                <Field ID="418" Name="duration" DataType="uint32">
                    <Value IsDefault="true">0u</Value>
                    <Description>Duration of test in seconds.</Description>
                </Field>
                <Field ID="419" Name="warmup" DataType="uint32">
                    <Value IsDefault="true">0u</Value>
                    <Description>Number of elements to warmup. Value 0 means no warmup.</Description>
                </Field>
                <Field ID="531" Name="count" DataType="uint32">
                    <Value IsDefault="true">0</Value>
                    <Description>Broadcast: number of messages per second. Request-response: number of requests to expect,</Description>
                </Field>
            </FieldList>
        </DataType>
    </DataTypeList>
    <AttributeList>
        <Attribute ID="122" Name="latency_setup" DataType="LantencySetup" Notify="OnChange">
            <Description>Current latency benchmark setup</Description>
        </Attribute>
    </AttributeList>
    <MethodList>
        <Method ID="123" Name="start_mode" MethodType="Request" Response="start_mode">
            <Description>Call to start or stop the latency benchmark test depending on the mode flag</Description>
            <ParamList>
                <Parameter ID="420" Name="mode" DataType="LatencyMode">
                    <Description>Latency benchmark test mode to start or prepare.</Description>
                </Parameter>
                <Parameter ID="421" Name="duration" DataType="uint32">
                    <Description>Duration of the test in seconds</Description>
                </Parameter>
                <Parameter ID="422" Name="warmup" DataType="uint32">
                    <Description>The number of elements to warmup. Value 0 means no warm up.</Description>
                </Parameter>
                <Parameter ID="532" Name="count" DataType="uint32">
                    <Description>Broadcast: number of messages per second. Request-response: number of requests to expect, plus warmup value.</Description>
                </Parameter>
            </ParamList>
        </Method>
        <Method ID="127" Name="start_mode" MethodType="Response">
            <Description>Response of latency benchmark test request</Description>
            <ParamList>
                <Parameter ID="423" Name="mode" DataType="LantencySetup">
                    <Description>The latency test mode that was setup</Description>
                </Parameter>
            </ParamList>
        </Method>
