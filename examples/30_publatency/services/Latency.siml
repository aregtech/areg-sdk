<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ServiceInterface FormatVersion="1.1.0">
    <Overview ID="51" Name="Latency" Version="1.0.0" Category="Public">
        <Description>A Service Interface for the latency benchmark</Description>
    </Overview>
    <DataTypeList>
        <DataType ID="52" Name="LatencyMode" Type="Enumeration" Values="uint16">
            <Description>Latency modes</Description>
            <FieldList>
                <EnumEntry ID="53" Name="Stop">
                    <Value>0</Value>
                    <Description>Stop latency test.</Description>
                </EnumEntry>
                <EnumEntry ID="54" Name="Broadcast0">
                    <Description>Send broadcasts with id and timestamp, no extra data</Description>
                </EnumEntry>
                <EnumEntry ID="55" Name="Broadcast8">
                    <Description>Send broadcasts with id and timestamp, and 8 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="56" Name="Broadcast16">
                    <Description>Send broadcasts with id and timestamp, and 16 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="57" Name="Broadcast32">
                    <Description>Send broadcasts with id and timestamp, and 32 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="58" Name="Broadcast64">
                    <Description>Send broadcasts with id and timestamp, and 64 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="59" Name="Broadcast128">
                    <Description>Send broadcasts with id and timestamp, and 128 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="60" Name="Broadcast256">
                    <Description/>
                </EnumEntry>
                <EnumEntry ID="61" Name="Broadcast512">
                    <Description>Send broadcasts with id and timestamp, and 512 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="62" Name="Broadcast1024">
                    <Description>Send broadcasts with id and timestamp, and 1024 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="63" Name="Broadcast4096">
                    <Description>Send broadcasts with id and timestamp, and 4096 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="64" Name="Broadcast65536">
                    <Description>Send broadcasts with id and timestamp, and 65536 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="65" Name="Request0">
                    <Description>Request/reply (ping-pong) with id and timestamp, and no extra data</Description>
                </EnumEntry>
                <EnumEntry ID="66" Name="Request8">
                    <Description>Request/reply (ping-pong) with id and timestamp, and 8 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="67" Name="Request16">
                    <Description>Request/reply (ping-pong) with id and timestamp, and 16 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="68" Name="Request32">
                    <Description>Request/reply (ping-pong) with id and timestamp, and 32 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="69" Name="Request64">
                    <Description>Request/reply (ping-pong) with id and timestamp, and 64 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="70" Name="Request128">
                    <Description>Request/reply (ping-pong) with id and timestamp, and 128 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="71" Name="Request256">
                    <Description>Request/reply (ping-pong) with id and timestamp, and 256 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="72" Name="Request512">
                    <Description>Request/reply (ping-pong) with id and timestamp, and 512 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="73" Name="Request1024">
                    <Description>Request/reply (ping-pong) with id and timestamp, and 1024 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="74" Name="Request4096">
                    <Description>Request/reply (ping-pong) with id and timestamp, and 4096 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="75" Name="Request65536">
                    <Description>Request/reply (ping-pong) with id and timestamp, and 65536 bytes extra data</Description>
                </EnumEntry>
                <EnumEntry ID="163" Name="QuitApp">
                    <Description>Quit and close all benchmark apps</Description>
                </EnumEntry>
                <EnumEntry ID="304" Name="Undefined">
                    <Description>Undefined mode.</Description>
                </EnumEntry>
            </FieldList>
        </DataType>
